{
  "name": "geocreuse-desktop",
  "version": "1.0.0",
  "main": "src/main.js",
  "scripts": {
    "dist": "electron-builder",
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "fr.geocreuse.backup",
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
